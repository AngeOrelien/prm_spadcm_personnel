# ==========================================================================
# Config d'environnement — MySPAD Pro (app Personnel)
#
# Pour basculer entre le backend local et le backend déployé sur Vercel,
# modifie UNIQUEMENT la ligne APP_ENV ci-dessous (valeurs : "local" | "vercel").
# Tout le reste du fichier peut rester tel quel.
# ==========================================================================

# --- Bascule active --------------------------------------------------------
APP_ENV=local

# --- Local : backend Node lancé en local (npm run dev sur le port 4000) ---
# Sur appareil/émulateur Android, on utilise `adb reverse tcp:4000 tcp:4000`
# pour que "localhost:4000" du téléphone pointe vers le backend de la machine.
API_BASE_URL_LOCAL=http://localhost:4000/api

# --- Vercel : backend déployé + MongoDB Atlas ------------------------------
API_BASE_URL_VERCEL=https://prmspadcmbackend.vercel.app/api
